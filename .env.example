# Environment
ENVIRONMENT=development
DEBUG=True

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=vocab_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy
# For local dev use localhost instead of db
# DATABASE_URL=postgresql://admin:secretpassword@localhost:5433/vocab_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Security
SECRET_KEY=your_generated_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Documentation Auth
DOCS_USERNAME=admin
DOCS_PASSWORD=capyvocab123

# CORS
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,https://admin.amidemy.uk.com

# Admin Startup
ADMIN_EMAIL=amidemy@admin.com
ADMIN_PASSWORD=amidemy@admin.com
